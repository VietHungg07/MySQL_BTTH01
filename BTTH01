-- Tạo bảng
CREATE TABLE Task (
    task_id INT PRIMARY KEY,
    task_name VARCHAR(50) NOT NULL,
    details TEXT,
    status BIT
);
-- Thêm dữ liệu
INSERT INTO Task (task_id, task_name, details, status)
VALUES 
(9, 'làm bài tập elearning', 'Làm bài tập session02 - Môn Cơ sở dữ liệu', 1),
(10, 'Học SQL cơ bản', 'Xem video hướng dẫn về lệnh INSERT và UPDATE', 0);
-- Cập nhật dữ liệu
UPDATE Task
SET status = 1
WHERE task_id = 10;
-- Xóa dữ liệu
DELETE FROM Task
WHERE task_id = 9;
-- Truy vấn tất cả
SELECT * FROM Task;
